{%- layout none -%}
<div data-ajax-container="search">
{% if search.performed %}
  {% assign downcased = search.terms | downcase %}
  {% assign keywords = "" %}
  {% for collection in collections %}
    {% assign title = collection.handle | downcase | replace: '-', ' ' %}
    {% if title contains downcased and collection.all_products_count > 0 %}
      {% assign keywords = keywords | append: title | append: ', ' %}
    {% endif %}
    {% for tag in collection.all_tags %}
      {% assign title = tag | downcase %}
        {% if title contains downcased %}
          {% assign keywords = keywords | append: title | append: ', ' %}
        {% endif %}
    {% endfor %}
  {% endfor %}
  {% assign keywords = keywords | remove_last: ', ' | split: ', ' | uniq  %}
  {% if keywords.size > 0 %}
  <div class="search_sugg-wrap">
    <!-- <h3 class="search_sugg-title">{{ 'general.search.popup_suggestions_label' | t }}</h3> -->
    <div class="swiper">
      <div class="swiper-wrapper">
          {% for item in keywords %}
            <div class="swiper-slide" style="order:{{ item.size }}">{{ item }}</div>
          {% endfor %}
      </div>
    </div>
    <div class="swiper-scrollbar"></div>
  </div>
  {% endif %}
  {%- paginate search.results by 50 -%}
    {% assign results = search.results | where: "object_type", 'product' %}
    {% if paginate.items > 0 %}
      <div class="search_prod-res-wrap">
      {%- for result in results -%}
        {%- if result.object_type == 'product' -%}
          <a class="search_prod-wrap" href="{{ result.url }}">
            <div class="search_prod-img-wrap">
            {{ result.featured_media | image_url: width: 300 | image_tag: class: 'search_prod-img' }}
            </div>
            <h4 class="search_prod-title">{{ result.title }}</h4>
            <span class="search_prod-price">{{ result.price_min | money }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
      </div>
    {% else %}
      <h4 class="search__empty-notice">{{ 'accessibility.search_results_no_results' | t: query: search.terms }} "{{ search.terms }}"</h4>
    {% endif %}
  {%- endpaginate -%}
{% else %}
  <div class="header__search-wrap  default">
    <div class="header__search-kewords-wrap">
      <h5 class="header__search_title">{{ 'accessibility.popular_searches' | t }}</h5>
      <div class="header__search-kewords">
          {% for link in linklists['suggested-search-terms'].links %}
              <a class="header__search-keyword link-underline" href="{{ link.url }}"data-keyword="{{ link.title }}">
                  <span class="link-underline-text">{{ link.title }}</span>
              </a>
          {% endfor %}
      </div>
    </div>
    {% if linklists['suggested-categories'].links != blank %}
    <div class="header__search_categories">
        <h5 class="header__search_title">{{ 'accessibility.search_by_category' | t }}</h5>
        <div class="swiper header__search_category-swiper">
            <div class="swiper-wrapper">
                {% for link in linklists['suggested-categories'].links %}
                    <div class="swiper-slide" data-link="{{ link.url }}">
                        {% assign collection = link.object %}
                        <a class="header__search_category link-underline" href="{{ collection.url }}"data-keyword="{{ link.title }}">
                            {% if collection.featured_image != blank %}
                                {{ collection.featured_image | image_url: width: 300 | image_tag: class: 'header__search_category-img' }}
                            {% else %}
                                {{ 'collection-1' | placeholder_svg_tag: 'header__search_category-img placeholder' }}
                            {% endif %}
                            <h5 class="header__search_category-title"><span class="link-underline-text">{{ collection.title | default: link.title }}</span></h5>
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% else %}
        <h4 class="search__empty-notice">{{ 'accessibility.search_results_no_results' | t: query: search.terms }}</h4>
    {% endif %}
    </div>
{% endif %}
  
  
</div>