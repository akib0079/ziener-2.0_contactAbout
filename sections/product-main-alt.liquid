  @media screen and (max-width: 749px) {
      .product-alt-section{
          padding: 20px 0 0px;
          display: flex;
          flex-direction: column;
      }
      .product-alt__grid{
          display: flex;
          flex-direction: column;
          grid-gap: 0;
      }
      .product-alt__left-wrap {
