      }
      .product-alt__right{
          display: grid;
          grid-template-columns: var(--full-page-grid-with-margins);
          padding: 29px 0 50px;
          z-index: 2;
          background: #FFF;
          border-radius: 10px 10px 0 0;
      }
      .popup-active .product-alt__right{
          z-index: unset;
      }
      .product-alt__right > *{
          grid-column: 2;
      }
      .product-alt__vendor{
          font-size: 14px;
      }
      .product-alt__title{
          font-size: 24px;
      }
      .product-alt__price{
          margin-top: 16px;
          font-size: 16px;
      }
      .product-alt__buy-quantity {
          display: none;
      }
      .product-alt__variant-picker{
          margin-top: 16px;
      }
      .product-alt__add-cart{
          height: auto;
          padding: 13px 20px;
          border-radius: 7px;
          font-size: 14px;
      }
      .product-alt__popup-content-inner{
          padding: 40px 30px 80px;
      }
      .product-alt__bt-card{
          height: auto;
          align-items: stretch;
      }
      .product-alt__bt-img-wrap{
          width: 110px;
          min-width: 110px;
          height: auto;
      }
      .product-alt__bt-info{
          padding: 8px 0;
          align-self: center;
      }
      .product-alt__bt-meta{
          gap: 8px;
      }
      .product-alt__bt-item-title{
          font-size: 12px;
          color: #000;
          line-height: normal;
      }
      .product-alt__bt-option-label {
          font-size: 11px;
          font-weight: 500;
      }
      .product-alt__bt-bottom{
          opacity: 1;
      }
      .product-alt__bt-size{
          height: 30px;
          font-size: 11px;
      }
      .product-alt__bt-add{
          width: 100px;
          height: 30px;
          font-size: 11px;
      }
      .rfmkr-product-main__share-modal {
          padding: 14px;
      }
      .rfmkr-product-main__share-modal-content {
          padding: 20px 16px;
          border-radius: 12px;
          margin: 0;
      }
      .rfmkr-product-main__share-modal-title {
          font-size: 18px;
      }
      .rfmkr-product-main__share-options{
