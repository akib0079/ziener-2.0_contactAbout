          max-width: calc(100vw - 40px);
          position: fixed;
          bottom: 40px;
          left: 50%;
          transform: translateX(-50%) translateY(50%);
          visibility: hidden;
          opacity: 0;
          z-index: 4;
          transition: 0.3s ease-out;
          transition-property: visibility, opacity, transform;
      }
      .product-sticky-bar .product-alt__bottom-bar{
          visibility: visible;
          opacity: 1;
          transform: translateX(-50%);
      }
      .product-alt__bb_left {
          display: flex;
          grid-gap: 10px;
          align-items: center;
      }
      .product-alt__bb_img-wrap{
          width: 64px;
