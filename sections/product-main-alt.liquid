          color: #4A4A4A;
          line-height: 100%;
          text-transform: capitalize;
          margin: 0;
      }
      .product-alt__bt-option-label{
          font-size: 14px;
          color: #202020;
          display: flex;
          gap: 13px;
          line-height: normal;
          margin-bottom: 8px;
      }
      .product-alt__bt-option-label strong{
          font-weight: 600;
      }
      .product-alt__bt-price{
          font-size: 14px;
          font-weight: 400;
          color: #000;
          line-height: normal;
          margin: 0;
      }
      .product-alt__bt-bottom{
          opacity: 0;
          transition: opacity 0.2s ease;
          margin-top: 10px;
      }
      .product-alt__bt-card:hover .product-alt__bt-bottom,
      .product-alt__bt-bottom--has-selection{
          opacity: 1;
      }
      .product-alt__bt-variants{
          display: flex;
          gap: 4px;
          flex-wrap: wrap;
      }
      .product-alt__bt-size{
          flex: 1 0 0;
          min-width: 0;
          height: 36px;
          display: flex;
          align-items: center;
          justify-content: center;
          border: 1px solid #E3E3E3;
          border-radius: 10px;
          background: #FFF;
          font-size: 12px;
          font-weight: 500;
          color: #202020;
          cursor: pointer;
          padding: 0 8px;
          transition: background 0.2s ease, border-color 0.2s ease;
          position: relative;
      }
      .product-alt__bt-size:hover:not(:disabled):not(.product-alt__bt-size--active){
          border-color: #ccc;
      }
      .product-alt__bt-size-check{
          display: none;
          width: 16px;
          height: 16px;
      }
      .product-alt__bt-size--active{
          background: #F7FAEB;
          border-color: #F7FAEB;
      }
      .product-alt__bt-size--active .product-alt__bt-size-label{
          display: none;
      }
      .product-alt__bt-size--active .product-alt__bt-size-check{
          display: block;
      }
      .product-alt__bt-size--unavail{
          color: #C0C0C0;
          cursor: not-allowed;
          position: relative;
      }
      .product-alt__bt-size--unavail .product-alt__bt-size-label{
          text-decoration: line-through;
      }
      /* Voeg toe button for products without variants */
      .product-alt__bt-add{
          width: 120px;
          height: 36px;
          display: flex;
          align-items: center;
          justify-content: center;
          border: 1px solid #E3E3E3;
          border-radius: 10px;
          background: #FFF;
          color: #202020;
          font-size: 14px;
          font-weight: 500;
          cursor: pointer;
          text-transform: uppercase;
          padding: 0;
          transition: border-color 0.2s ease;
      }
      .product-alt__bt-add:hover{
          border-color: #ccc;
      }
      .product-alt__bt-add:disabled{
          opacity: 0.3;
          cursor: not-allowed;
      }
      .product-alt__bt-add--added{
          background: #F7FAEB;
          border-color: #F7FAEB;
          color: #636B40;
      }
      /* Reviews */
      .product-alt__reviews{
          display: flex;
          align-items: center;
          gap: 4px;
          margin-top: 4px;
      }
      .product-alt__reviews-stars{
          display: flex;
          align-items: center;
          gap: 1px;
      }
      .product-alt__star{ width: 15px; height: 15px; }
      .product-alt__reviews-link{
          font-size: 14px;
          font-weight: 500;
          color: #5C5C5C;
          text-decoration: underline;
          text-underline-offset: 2px;
      }
      .product-alt__reviews-link:hover{ color: #202020; }
      /* Payment Icons */
      .product-alt__payment-icons{
          display: flex;
          align-items: center;
          justify-content: center;
          margin-top: 30px;
      }
      .product-alt__payment-img{
          max-width: 100%;
          height: 22px;
          object-fit: contain;
      }
      /* USPs */
      .product-alt__usps{
          display: flex;
          flex-direction: column;
          gap: 8px;
          margin-top: 30px;
          padding-bottom: 30px;
          border-bottom: 1px solid #E4E4E4;
      }
      .product-alt__usp{
          display: flex;
          align-items: center;
          gap: 6px;
          font-size: 14px;
          font-weight: 400;
          line-height: 1.2;
          color: #202020;
      }
      .product-alt__usp svg{
          width: 16px;
          height: 17px;
          flex-shrink: 0;
      }
      .product-alt__usp-icon{
          flex-shrink: 0;
          object-fit: contain;
      }

      /* ============================================
       Share Modal
       ============================================ */
    .rfmkr-product-main__share-modal {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .rfmkr-product-main__share-modal.is-open {
      opacity: 1;
      visibility: visible;
    }

    .rfmkr-product-main__share-modal-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
    }

    .rfmkr-product-main__share-modal-content {
      position: relative;
      background: #FFFFFF;
      border-radius: 16px;
      padding: 30px;
      max-width: 420px;
      width: 100%;
      transform: scale(0.95);
      transition: transform 0.3s var(--rfmkr-spring);
    }

    .rfmkr-product-main__share-modal.is-open .rfmkr-product-main__share-modal-content {
      transform: scale(1);
    }

    .rfmkr-product-main__share-modal-close {
      position: absolute;
      top: 15px;
      right: 15px;
      width: 32px;
      height: 32px;
      background: var(--rfmkr-bg-light);
      border: none;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s ease;
    }

    .rfmkr-product-main__share-modal-close:hover {
      background: var(--rfmkr-bg-lighter);
    }

    .rfmkr-product-main__share-modal-title {
      font-weight: 600;
      font-size: 18px;
      color: var(--rfmkr-text-black);
      margin: 0 0 20px;
    }

    .rfmkr-product-main__share-options {
      display: flex;
      gap: 15px;
      margin-bottom: 20px;
    }

    .rfmkr-product-main__share-option {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      padding: 15px;
      background: var(--rfmkr-bg-light);
      border: none;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
      color: var(--rfmkr-text-black);
      font-size: 12px;
      transition: background 0.2s ease, transform 0.15s var(--rfmkr-ease-out);
    }

    .rfmkr-product-main__share-option:hover {
      background: var(--rfmkr-bg-lighter);
      transform: translateY(-2px);
    }

    .rfmkr-product-main__share-option svg {
      width: 24px;
      height: 24px;
    }

    .rfmkr-product-main__share-link {
      display: flex;
      gap: 10px;
    }

    .rfmkr-product-main__share-link-input {
      flex: 1;
      padding: 12px 16px;
      background: var(--rfmkr-bg-light);
      border-radius: 10px;
      font-size: 14px;
      color: var(--rfmkr-text-700);
      border: 1.5px solid #bfbfbf;
    }

    .rfmkr-product-main__share-link-btn {
      padding: 10px 20px;
      background: var(--rfmkr-primary);
      border: none;
      border-radius: 10px;
      font-weight: 600;
      font-size: 14px;
      color: #FFFFFF;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .rfmkr-product-main__share-link-btn:hover {
      background: var(--rfmkr-primary-hover);
    }
    /* Block: Action Buttons - Exact Figma match */
    .rfmkr-product-main__actions {
      margin-top: 10px;
      display: flex;
      gap: 12px;
    }

    .rfmkr-product-main__action-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 32px;
      padding: 4px 10px;
      background: #F8F8F8;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      color: #636B40;
      transition: background 0.2s ease,
                  color 0.2s ease,
                  transform 0.15s var(--rfmkr-ease-out, ease-out);
    }

    .rfmkr-product-main__action-btn:hover {
      background: #fcfcfc;
      transform: translateY(-1px);
    }

    .rfmkr-product-main__action-btn:active {
      transform: translateY(0);
    }

    .rfmkr-product-main__action-btn svg,
    .rfmkr-product-main__action-btn img {
      width: 20px;
      height: 20px;
      transition: transform 0.2s var(--rfmkr-spring);
      object-fit: contain;
    }

    .rfmkr-product-main__action-btn--wishlist:hover svg,
    .rfmkr-product-main__action-btn--wishlist:hover img,
    .rfmkr-product-main__action-btn--wishlist.rfmkr-product-main__action-btn--active svg,
    .rfmkr-product-main__action-btn--wishlist.rfmkr-product-main__action-btn--active img {
      transform: scale(1.15);
    }

    .rfmkr-product-main__action-btn--active {
      background: #FFF0E6;
      color: var(--rfmkr-primary);
    }

    .rfmkr-product-main__action-btn--active svg path {
      fill: var(--rfmkr-primary);
      stroke: var(--rfmkr-primary);
    }

      .product-alt__bottom-bar{
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding:12px;
          border-radius: 10px;
          background: #FFF;
          box-shadow: 0 0 30px 0 rgba(0, 0, 0, 0.10);
