{% comment %} {% render 'specs-label.liquid' %} {% endcomment %}
<script>
  const container = document.querySelector('.section-id-{{ section.id }}');
  updateAvailableState(Theme.currentProduct, container);
  {% comment %} if(container.classList.contains('variant-based-gallery')){
    separateGallery(Theme.currentProduct, container);
  } {% endcomment %}
  {% comment %} container.querySelectorAll('.product-alt__popup').forEach((popup) => {
    popup.querySelector('.product-alt__popup-anchor')?.addEventListener('click', (e) => {
      e.preventDefault();
      popup.classList.add('active');
      document.body.classList.add('popup-active');
    });
    popup.querySelector('.product-alt__popup-close')?.addEventListener('click', (e) => {
      e.preventDefault();
      popup.classList.remove('active');
      document.body.classList.remove('popup-active');
    });
    popup.querySelector('.product-alt__popup-bg')?.addEventListener('click', (e) => {
      e.preventDefault();
      popup.classList.remove('active');
      document.body.classList.remove('popup-active');
    });
  });
  container.querySelectorAll('.specifications').forEach((spec) => {
    spec.querySelectorAll('h5,h4').forEach((heading) => {
      if (heading.nextElementSibling?.tagName != 'UL') {
        heading.remove();
      }
    });
  }); {% endcomment %}

  /* ── Metaobject Specs: parse JSON and build spec rows ── */
  {% comment %} container.querySelectorAll('[data-metaobject-specs]').forEach((specsEl) => {
    try {
      const data = JSON.parse(specsEl.getAttribute('data-metaobject-specs'));
      if (!data) return;

      const skip = [
        'id',
        'admin_graphql_api_id',
        'handle',
        'display_name',
        'updated_at',
        'created_at',
        'type',
        'categorie_type',
      ];
      const ul = specsEl.querySelector('ul');
      if (!ul) return;

      for (const [key, value] of Object.entries(data)) {
        if (skip.some((s) => key.toLowerCase().includes(s))) continue;

        let displayValue;
        if (value === true || value === 'true') displayValue = 'Ja';
        else if (value === false || value === 'false') displayValue = 'Nee';
        else if (value === null || value === undefined || value === '') continue;
        else if (Array.isArray(value)) displayValue = value.join(', ');
        else displayValue = String(value);

        if (displayValue.trim() === '' || displayValue === '0') continue;

        const label = Theme.specs_label[key] || key.replace(/[_-]/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
        const li = document.createElement('li');
        li.innerHTML = `<span class="heading">${label}</span><span class="text">${displayValue}</span>`;
        ul.appendChild(li);
      }

      if (ul.children.length === 0) {
        specsEl.closest('.product-alt__desc-wrap')?.remove();
      }
    } catch (e) {
      console.error('Metaobject specs parse error:', e);
    }
  }); {% endcomment %}
  {% comment %} container.querySelectorAll('.product-alt__buy-quantity').forEach((qty) => {
    const qtyInput = qty.querySelector('.product-alt__buy-qty-input');
    const minusBtn = qty.querySelector('[data-qty-minus]');
    const plusBtn = qty.querySelector('[data-qty-plus]');
    if (minusBtn && qtyInput) {
      minusBtn.addEventListener('click', function () {
        const val = parseInt(qtyInput.value) || 1;
        if (val > 1) qtyInput.value = val - 1;
      });
    }

    if (plusBtn && qtyInput) {
      plusBtn.addEventListener('click', function () {
        const val = parseInt(qtyInput.value) || 1;
        qtyInput.value = val + 1;
      });
    }
  }); {% endcomment %}
  {% comment %} container.querySelectorAll('.product-alt__option-selector').forEach((selector) => {
    selector.style.setProperty('--height', selector.scrollHeight + 'px');
  }); {% endcomment %}
  {% comment %} container.querySelectorAll('.product-form').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('.product-alt__add-cart');
      const variantId = form.querySelector('[data-input-curr-variant-id]').value;
      btn.classList.add('btn--in-progress');
      fetch(Theme.routes.cart_add_url, {
        method: 'POST',
        body: JSON.stringify({
          items: [
            {
              id: variantId,
              quantity: form.querySelector('.product-alt__buy-qty-input')?.value || 1,
            },
          ],
        }),
        headers: {
          'Content-Type': 'application/json',
        },
      })
        .then((response) => {
          btn.classList.remove('btn--in-progress');
          return response.json();
        })
        .then((response) => {
          if (!response.status || response.status === 200) {
            document.dispatchEvent(new CustomEvent('Theme:cartchanged', { bubbles: true, cancelable: false }));
            document.dispatchEvent(
              new CustomEvent('cart:update', {
                detail: {
                  data: {
                    source: 'quick-add',
                    variantId: variantId,
                  },
                },
              })
            );
            btn.classList.add('check');
            setTimeout(() => {
              btn.classList.remove('check');
            }, 1500);
          } else if (response.description) {
            Theme.showQuickPopup(response.description, btn);
          }
        });
    });
  }); {% endcomment %}

  {% comment %} container.addEventListener('variant_changed', (e) => {
    const variant = e.detail.variant;
    updateVariantURL(variant);
    updateSelectedOptions(variant, container);
    updateVariantVisibilityArea(variant, container);
    updateAvailableState(e.detail.product, container);
    updateButButtons(variant, container);
    if(container.classList.contains('variant-based-gallery')){
      updateActiveGallery(variant, container);
    }
  }); {% endcomment %}
  function updateButButtons(variant, container) {
    container.querySelectorAll('[data-input-curr-variant-id]').forEach((input) => {
      input.value = variant.id;
    });
    container.querySelectorAll('.product-alt__buy-buttons .product-alt__add-cart').forEach((btn) => {
      if(variant.available && btn.dataset.addToCartText){
        btn.innerHTML = btn.dataset.addToCartText
      }else if(!variant.available && btn.dataset.soldOutText){
        btn.innerHTML = btn.dataset.soldOutText
      }
      btn.toggleAttribute('disabled', !variant.available);
    });
  }
  function updateVariantURL(variant) {
    if (variant) {
      var newurl =
        window.location.protocol + '//' + window.location.host + window.location.pathname + '?variant=' + variant.id;
      window.history.replaceState({ path: newurl }, '', newurl);
    }
  }
  function updateSelectedOptions(variant, container = document) {
    if (variant) {
      variant.options.forEach((opt, i) => {
        container.querySelectorAll('.product-alt__option-selectors').forEach((selectors) => {
          const node = selectors.querySelector(`[data-option-index="${i}"] .product-alt__selected_option`);
          if (node) node.innerText = opt;
        });
      });
    }
  }
  function updateVariantVisibilityArea(variant, container) {
    container.querySelectorAll('.variant-visibility-area').forEach((area) => {
      Array.from(area.children).forEach((child) => {
        if (child.tagName !== 'SCRIPT') {
          child.remove();
        }
      });

      const variantId = variant ? variant.id : '';
      const script = area.querySelector(`script[data-variant-id="${variantId}"]`);

      if (script) {
        area.insertAdjacentHTML('beforeend', script.innerHTML);
      }
    });
  }
  function updateAvailableState(productData, container) {
    const optionStatusMap = [];
    const currentSelectedOptionValues = [];

    // Collect current selected option values
    container
      .querySelectorAll('.product-alt__option-selectors[data-disable-unavailable] .product-alt__option-selector')
      .forEach((selector) => {
        const checkedInput = selector.querySelector('input:checked');
        let value = null;
        if (checkedInput) {
          value = checkedInput.value;
        }

        currentSelectedOptionValues.push(value);
      });

    // Build option value map
    productData.options.forEach((optionName, optionIndex) => {
      const values = {};

      productData.variants.forEach((variant) => {
        const optionValue = variant.options[optionIndex];
        if (!(optionValue in values)) {
          values[optionValue] = false;
        }
      });

      optionStatusMap.push({
        name: optionName,
        values,
      });
    });

    // Determine availability per option value
    productData.options.forEach((optionName, optionIndex) => {
      const fixedOptions = currentSelectedOptionValues.slice(0, optionIndex);

      Object.keys(optionStatusMap[optionIndex].values).forEach((optionValue) => {
        const fixedOptionsForValue = [...fixedOptions, optionValue];

        let availableVariantExists = false;

        productData.variants.forEach((variant) => {
          let variantComplies = true;

          fixedOptionsForValue.forEach((fixedValue, idx) => {
            if (fixedValue && fixedValue != variant.options[idx]) {
              variantComplies = false;
            }
          });

          if (variantComplies && variant.available) {
            availableVariantExists = true;
          }
        });

        optionStatusMap[optionIndex].values[optionValue] = availableVariantExists;
      });
    });
    // Apply unavailable state to UI
    optionStatusMap.forEach((option, optionIndex) => {
      let available = false;
      Object.entries(option.values).forEach(([optionValue, isAvailable]) => {
        // Listed (radio / swatch)
        available = available || isAvailable;
        container
          .querySelectorAll(`.product-alt__option-selector[data-option-index="${optionIndex}"] .product-alt__opt-btn`)
          .forEach((btn) => {
            if (btn.value === optionValue) {
              btn.classList.toggle('is-unavailable', !isAvailable);
            }
          });
      });
      container
        .querySelector(`.product-alt__option-selector[data-option-index="${optionIndex}"]`)
        ?.classList.toggle('is-unavailable', !available);
    });
  }
  function updateActiveGallery(variant, container) {
    if (variant) {
      const activeGallery = container.querySelector(`.product-alt__gallery-wrap[data-variant-image-group="${variant.option1}"]`);
      if(activeGallery){
        container.querySelector('.product-alt__gallery-wrap.active').classList.remove('active')
        activeGallery.classList.add('active');
        container.querySelector('.product-alt__gallery-wrap-outer').style.setProperty('--height', activeGallery.scrollHeight + 'px');
      }
    }
  }

  function separateGallery(productData, container) {
    {% comment %} console.log(productData) {% endcomment %}
    let optionNameMediaMap = {}, groupingOptionIndex = 0;
    productData.media.forEach((media) => {
        productData.variants.forEach((variant) => {
            if (variant.featured_media && variant.featured_media.id == media.id) {
                if (!optionNameMediaMap[variant.options[groupingOptionIndex]]) {
                    optionNameMediaMap[variant.options[groupingOptionIndex]] = media.id;
                }
            }
        });
    });
    let currentMediaOptionName = '';
    let mainSwiperCont = container.querySelector(".product-alt__gallery-wrap");
    container.querySelectorAll('.product-alt__gallery .swiper-slide').forEach(function (item, index) {
    for (let optionName in optionNameMediaMap) {
        if (item.dataset.mediaId == optionNameMediaMap[optionName]) {
        currentMediaOptionName = optionName;
        }
    }
    let currMainSwiperCont = container.querySelector(`.product-alt__gallery-wrap[data-variant-image-group="${currentMediaOptionName}"]`);
    if(currMainSwiperCont == undefined){
        currMainSwiperCont = mainSwiperCont.cloneNode(true);
        currMainSwiperCont.setAttribute('data-variant-image-group', currentMediaOptionName);
        currMainSwiperCont.querySelector('.product-alt__thumb .swiper-wrapper').replaceChildren();
        currMainSwiperCont.querySelector('.product-alt__gallery .swiper-wrapper').replaceChildren();
        mainSwiperCont.insertAdjacentElement('afterend', currMainSwiperCont);
    }
    currMainSwiperCont.querySelector('.product-alt__gallery .swiper-wrapper').append(item)
    currMainSwiperCont.querySelector('.product-alt__thumb .swiper-wrapper').append(mainSwiperCont.querySelector(`.product-alt__thumb .swiper-slide[data-media-id="${item.dataset.mediaId}"]`))
    // $(item).attr('data-variant-image-group', currentMediaOptionName);
    });
    mainSwiperCont.remove();
    const deskThumbLimit = parseInt(container.querySelector(".product-alt__gallery-wrap-outer").dataset.thumbLimit);
    const mobThumbLimit = parseInt(container.querySelector(".product-alt__gallery-wrap-outer").dataset.thumbLimitMob);
    const thumbOverlayTemplate = container.querySelector('#thumb-overlay-template');
    if(deskThumbLimit && thumbOverlayTemplate){
        container.querySelectorAll(".product-alt__gallery-wrap").forEach(gallery => {
            const thumbSlider = gallery.querySelector('.product-alt__thumb .swiper-wrapper');
            const childLength = thumbSlider.children.length;
            if(childLength > deskThumbLimit){
                while (thumbSlider.children.length > deskThumbLimit) {
                    thumbSlider.removeChild(thumbSlider.lastElementChild);
                }
                const wrapper = document.createElement('div');
                wrapper.innerHTML = thumbOverlayTemplate.innerHTML;
                let overlay = wrapper.querySelector('.product-alt__thumb_overlay');
                overlay.querySelector('span').textContent = (childLength - deskThumbLimit) + '+';
                thumbSlider.lastElementChild.appendChild(overlay);
                if(mobThumbLimit < deskThumbLimit){
                    wrapper.innerHTML = thumbOverlayTemplate.innerHTML;
                    overlay = wrapper.querySelector('.product-alt__thumb_overlay');
                    overlay.classList.add('desktop:hidden')
                    overlay.querySelector('span').textContent = (childLength - mobThumbLimit) + '+';
                    thumbSlider.querySelector(`.swiper-slide:nth-child(${mobThumbLimit})`).appendChild(overlay);
                    for (let i = mobThumbLimit; i <= deskThumbLimit; i++) {
                        thumbSlider.querySelector(`.swiper-slide:nth-child(${mobThumbLimit})`).classList.add('mobile:hidden')
                    }
                }
            }
            
        })
    }
    let activeGallery = container.querySelector('.product-alt__gallery-wrap');
    const preselected = container.querySelector('.product-alt__gallery-wrap-outer').dataset.preSelectedGroup;
    if(preselected)
    activeGallery = container.querySelector(`.product-alt__gallery-wrap[data-variant-image-group="${preselected}"]`);
    activeGallery.classList.add('active');
    container.querySelector('.product-alt__gallery-wrap-outer').style.setProperty('--height', activeGallery.scrollHeight + 'px');
}
  document.addEventListener('DOMContentLoaded', () => {
    {% comment %} document.querySelectorAll('.section-id-{{ section.id }} .product-alt__gallery-wrap').forEach(galleryWrap => {
        const thumbsSwiper = new Swiper(galleryWrap.querySelector('.product-alt__thumb'), {
            slidesPerView: 'auto',
            freeMode: {
                enabled: true,
                sticky: true,
                momentumRatio: 0.8,
            },
            breakpoints: {
                750: {
                direction: 'vertical',
                },
            },
        });
        const gallerySwiper = new Swiper(galleryWrap.querySelector('.product-alt__gallery'), {
            slidesPerView: 1,
            effect: 'fade',
            thumbs: {
                swiper: thumbsSwiper,
            },
            navigation: {
                nextEl: galleryWrap.querySelector('.slider_nav.nav-next'),
                prevEl: galleryWrap.querySelector('.slider_nav.nav-prev'),
            },
        });
    }) {% endcomment %}
    {% comment %} document.querySelector('.section-id-{{ section.id }}').addEventListener('variant_changed', (e) => {
      const selector = e.target.closest('.product-alt__option-selector');
      if (selector == null || selector.dataset.optionIndex != 0) return;
      const { variant } = e.detail;
      const mediaId = variant.featured_media?.id || variant.featured_image?.id;
      if (!mediaId || !gallerySwiper) return;
      const slideIndex = [...gallerySwiper.slides].findIndex((slide) => slide.dataset.mediaId == mediaId);

      if (slideIndex === -1) return;

      gallerySwiper.slideTo(slideIndex);
    }); {% endcomment %}

    // ============================================
    // BOUGHT TOGETHER - Add to Cart
    // ============================================
    {% comment %} container.querySelectorAll('[data-bt-card]').forEach((card) => {
      // Parse variants JSON
      const variantsScript = card.querySelector('[data-bt-variants]');
      const variants = variantsScript ? JSON.parse(variantsScript.textContent) : [];
      const optionIndex = parseInt(card.querySelector('[data-bt-option-index]')?.dataset.btOptionIndex ?? -1);

      // Size variant buttons
      card.querySelectorAll('.product-alt__bt-size:not(.product-alt__bt-size--unavail)').forEach((btn) => {
        btn.addEventListener('click', function () {
          const variantsWrap = this.closest('.product-alt__bt-variants');
          if (variantsWrap) variantsWrap.classList.add('product-alt__bt-variants--has-selection');
          const bottom = card.querySelector('.product-alt__bt-bottom');
          if (bottom) bottom.classList.add('product-alt__bt-bottom--has-selection');
          // Update label
          const optionValue = this.dataset.btOptionValue;
          const label = card.querySelector('[data-bt-selected-label]');
          if (label) label.textContent = optionValue;
          // Find first available variant with this option value
          const matchingVariant = variants.find((v) => v.options[optionIndex] === optionValue && v.available);
          if (!matchingVariant) return;
          btn.classList.add('btn--in-progress');
          // Add to cart
          fetch(Theme.routes.cart_add_url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id: matchingVariant.id, quantity: 1 }] }),
          })
            .then((r) => r.json())
            .then((res) => {
              btn.classList.remove('btn--in-progress');
              if (!res.status || res.status === 200) {
                this.classList.add('product-alt__bt-size--active');
                document.dispatchEvent(new CustomEvent('Theme:cartchanged', { bubbles: true }));
                document.dispatchEvent(
                  new CustomEvent('cart:update', {
                    detail: { data: { source: 'bought-together', variantId: matchingVariant.id } },
                  })
                );

                setTimeout(() => {
                  this.classList.remove('product-alt__bt-size--active');
                  if (bottom) bottom.classList.remove('product-alt__bt-bottom--has-selection');
                }, 2000);
              }
            });
        });
      });
      // Single "Voeg toe" button for products without variants
      const addBtn = card.querySelector('.product-alt__bt-add');
      if (addBtn) {
        addBtn.addEventListener('click', function () {
          const variantId = this.dataset.btVariantId;
          const bottom = card.querySelector('.product-alt__bt-bottom');
          addBtn.classList.add('btn--in-progress');
          fetch(Theme.routes.cart_add_url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] }),
          })
            .then((r) => r.json())
            .then((res) => {
              addBtn.classList.remove('btn--in-progress');
              if (!res.status || res.status === 200) {
                this.textContent = '✓ Toegevoegd';
                this.classList.add('product-alt__bt-add--added');
                if (bottom) bottom.classList.add('product-alt__bt-bottom--has-selection');
                document.dispatchEvent(new CustomEvent('Theme:cartchanged', { bubbles: true }));
                document.dispatchEvent(
                  new CustomEvent('cart:update', { detail: { data: { source: 'bought-together', variantId } } })
                );
                setTimeout(() => {
                  this.textContent = 'Voeg toe';
                  this.classList.remove('product-alt__bt-add--added');
                  if (bottom) bottom.classList.remove('product-alt__bt-bottom--has-selection');
                }, 2000);
              } else {
                this.textContent = 'Voeg toe';
              }
            });
        });
      }
    }); {% endcomment %}

    // ============================================
    // SHARE MODAL
    // ============================================
    {% comment %} const shareBtn = container.querySelector('[data-share-btn]');
    const shareModal = container.querySelector('[data-share-modal]');
    const shareModalClose = container.querySelectorAll('[data-share-modal-close]');
    const copyLinkBtns = container.querySelectorAll('[data-copy-link]');

    if (shareBtn && shareModal) {
      shareBtn.addEventListener('click', () => {
        shareModal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      });
      shareModalClose.forEach((btn) => {
        btn.addEventListener('click', () => {
          shareModal.classList.remove('is-open');
          document.body.style.overflow = '';
        });
      });
    }

    copyLinkBtns.forEach((btn) => {
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          const orig = btn.textContent || 'Kopieren';
          btn.textContent = 'Kopiert!';
          setTimeout(() => {
            btn.textContent = orig;
          }, 2000);
        } catch (err) {
          // Fallback for older browsers
          const input = section.querySelector('.rfmkr-product-main__share-link-input');
          if (input) {
            input.select();
            document.execCommand('copy');
            const orig = btn.textContent || 'Kopieren';
            btn.textContent = 'Kopiert!';
            setTimeout(() => {
              btn.textContent = orig;
            }, 2000);
          }
        }
      });
    }); {% endcomment %}

    const bottomBar = container.querySelector('.product-alt__bottom-bar');
    const buyButton = container.querySelector('.product-alt__right .product-alt__add-cart');
    if (bottomBar && buyButton) {
      setTimeout(() => {
        const height = document.querySelector('#header-component')?.offsetHeight || 0;
        ScrollTrigger.create({
          trigger: buyButton,
          start: `bottom top+=${height}`,
          onEnter: (self) => document.body.classList.add('product-sticky-bar'),
          onLeaveBack: (self) => document.body.classList.remove('product-sticky-bar'),
        });
      }, 500);
    }
  });
</script>
